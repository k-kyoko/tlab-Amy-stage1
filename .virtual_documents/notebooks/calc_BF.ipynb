project_root = os.path.abspath("/home/jovyan/work")

if project_root not in sys.path:
    sys.path.append(project_root)

from funcs import core, viz


path_data = project_root + "/data/raw"
df_bdi = pd.read_csv(path_data + "/BDI_score.csv", header=0)
bdi_col_name = df_bdi.columns[1]


# Load and modify dataframe

df_amy_raw = pd.read_csv(path_data + "/Amy_dissimilarity.csv", header=None)

word1_row = df_amy_raw.iloc[0].astype(str)
word2_row = df_amy_raw.iloc[1].astype(str)

new_columns = ['Sub']
for i in range(1, len(df_amy_raw.columns)):
    col_name = f"{word1_row[i]}_{word2_row[i]}"
    new_columns.append(col_name)

df_amy_data = df_amy_raw.iloc[2:].copy()

df_amy_data.columns = new_columns
df_amy_data = df_amy_data.apply(pd.to_numeric, errors='coerce')


df_merged = pd.merge(df_amy_data, df_bdi, on="Sub", how="inner")


# Calculate spearman's rank correlation
word_pair_cols = [col for col in df_merged.columns if col not in ['Sub', bdi_col_name]]
results = []

for wp_col in word_pair_cols:
    valid_data = df_merged[['Sub', wp_col, bdi_col_name]].dropna()

    if len(valid_data) > 2:
        r_val, p_val = stats.spearmanr(valid_data[wp_col], valid_data[bdi_col_name])

        results.append({
            'Word_Pair': wp_col,
            'N_Subjects': len(valid_data),
            'Spearman_rho': r_val,
            'p_value': p_val
        })

df_results = pd.DataFrame(results)


# Apply Multiple Testing Correction (False Discovery Rate - Benjamini-Hochberg)
reject, pvals_corrected, _, _ = mt.multipletests(df_results['p_value'], alpha=0.05, method='fdr_bh')

df_results['p_value_FDR_corrected'] = pvals_corrected
df_results['Significant_FDR_0.05'] = reject
df_results.sort_values(by='p_value', inplace=True)

# Add Fisher's z-transformed Spearman's rho
df_results['z_transformed_corr'] = np.arctanh(df_results['Spearman_rho'])

print("Top 10 most correlated word pairs:")
print(df_results.head(10))

output_filename = project_root + '/data/processed/corr_fdr.csv'
df_results.to_csv(output_filename, index=False)
print(f"\nAll results successfully saved to {output_filename}")


