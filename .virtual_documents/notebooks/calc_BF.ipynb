# Sequential DF10 simulation

# Checkpoint of sequential simulation
N_steps = list(range(100, 1001, 1))
threshold_H1 = 6.0
threshold_H0 = 1 / 6.0
word_cols = [col for col in df_merged.columns if col not in ['Sub', 'BDI']]

plt.figure(figsize=(10, 8))

# Create massive subjects list (N=1000)
df_virtual_experiment = df_merged.sample(n=max(N_steps), replace=True).reset_index(drop=True)

for word in word_cols:
    n_history = []
    bf_history = []

    for N in N_steps:
        current_data = df_virtual_experiment.head(N)  # Use cumulative data

        r = current_data[word].corr(current_data['BDI'], method='spearman')
        if pd.isna(r): r = 0
        r = np.clip(r, -0.999, 0.999)
        bf10 = pg.bayesfactor_pearson(r, n=N)

        n_history.append(N)
        bf_history.append(bf10)

        # Stop loop
        if bf10 >= threshold_H1 or bf10 <= threshold_H0:
            break

    # Plot trajectory
    plt.plot(n_history, bf_history, marker='o', markersize=3, alpha=0.4)

    final_n = n_history[-1]
    final_bf = bf_history[-1]
    #plt.text(final_n + 15, final_bf, word, fontsize=8, verticalalignment='center')

plt.axhline(threshold_H1, color='red', linestyle='--', linewidth=1.5, label='H1 Threshold (6.0)')
plt.axhline(threshold_H0, color='blue', linestyle='--', linewidth=1.5, label='H0 Threshold (1/6)')
plt.axhline(1.0, color='gray', linestyle=':', alpha=0.5)
plt.yscale('log')

plt.yticks([0.01, 1/6, 1, 6, 100, 10000], ['0.01', '1/6 (H0)', '1', '6 (H1)', '100', '10000'])
plt.xlabel('Sample Size (N)', fontsize=12)
plt.ylabel('Bayes Factor ($BF_{10}$) - Log Scale', fontsize=12)
plt.title('Sequential BF10 Testing Trajectories', fontsize=14)
plt.grid(True, alpha=0.2)
plt.legend(loc='upper left')
plt.xlim(80, 600)  #max(N_steps) + 50)
plt.ylim(0.07, 400)

plt.tight_layout()
plt.savefig(project_root + "/outputs/figs/sequential_trajectories_100.png", dpi=300)
plt.show()



